{
  "name": "ergon-ole-miss-hackathon-template",
  "private": true,
  "version": "1.0.0",
  "description": "Template repo for Ergon's 2026 Ole Miss Hackathon challenge.",
  "type": "module",
  "scripts": {
    "prepare": "husky && echo npx lint-staged > .husky/pre-commit",
    "prettier": "prettier --write \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger}\"",
    "prettier:debug": "prettier --check --loglevel debug \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger}\"",
    "prettier:verify": "prettier --list-different \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger}\"",
    "test:unit": "sfdx-lwc-jest",
    "test:unit:debug": "sfdx-lwc-jest --debug",
    "test:unit:watch": "sfdx-lwc-jest --watch",
    "test:unit:coverage": "sfdx-lwc-jest --coverage",
    "lint": "npm run lint:lwc",
    "lint:lwc": "eslint force-app/main/default/lwc",
    "lint:fix": "eslint . --fix",
    "lint:js": "eslint '**/*.js'",
    "lint:html": "eslint '**/*.html'",
    "lint:aura": "eslint '**/*.cmp"
  },
  "devDependencies": {
    "@prettier/plugin-xml": "^3.4.1",
    "@salesforce/sfdx-lwc-jest": "^6.0.1",
    "eslint": "^9.14.0",
    "eslint-define-config": "^2.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "prettier-plugin-apex": "^2.1.5"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{cls,cmp,component,css,html,js,json,md,page,trigger}": [
      "prettier --write"
    ]
  }
}
